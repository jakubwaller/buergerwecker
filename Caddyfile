# Primary site.
buergerwecker.de {
    # The site is proxied by Cloudflare. The app keys its per-IP rate limit on
    # CF-Connecting-IP (real visitor IP); strip that header whenever the
    # connection does NOT originate from Cloudflare's published ranges
    # (https://www.cloudflare.com/ips/), so direct requests can't spoof it.
    # Caddy itself already replaces client-supplied X-Forwarded-For with the
    # peer IP (default since v2.5, no trusted_proxies configured).
    @not_cloudflare not remote_ip 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
    request_header @not_cloudflare -CF-Connecting-IP
    reverse_proxy web:8000
}

# Keep the old domain working: confirmation / manage / unsubscribe links in
# emails already sent point at termine.jakubwaller.eu. A permanent redirect
# preserves them (tokens stay valid — same backend). Keep this indefinitely.
termine.jakubwaller.eu {
    redir https://buergerwecker.de{uri} permanent
}
